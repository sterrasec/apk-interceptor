<resources>
    <style name="Theme.ApkInterceptor" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>

    <!-- Used by InterceptActivity, which only logs the deeplink and immediately
